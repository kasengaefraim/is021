        Console.WriteLine()

        Console.WriteLine("Main concepts:")
        Console.WriteLine("- Classes and Objects")
        Console.WriteLine("- Encapsulation")
        Console.WriteLine("- Inheritance")
        Console.WriteLine("- Polymorphism")

    End Sub

End Class