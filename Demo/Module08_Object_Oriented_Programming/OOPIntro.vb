Public Class OOPIntro
    Implements ISlide

    Public Sub Show() Implements ISlide.Show

        Console.WriteLine("=== OBJECT-ORIENTED PROGRAMMING (OOP) ===")
        Console.WriteLine()

        Console.WriteLine("OOP is a programming style based on objects and classes.")
        Console.WriteLine()

        Console.WriteLine("Why OOP?")
        Console.WriteLine("- Organizes code into reusable parts")
        Console.WriteLine("- Models real-world objects")
